      "source": {
        "ref": "internal://webnovel-method-pack/chapter-end-hook",
        "kind": "derived-method",
        "basis": "章末钩子必须改变读者对下一步的预期，并让下一章存在可执行的首要问题。",
        "sha256": "59f2313bd8498d620c60d13ae89aa098a5343a9c61465088946f60bda5b32b10"
      }
    },
    {
