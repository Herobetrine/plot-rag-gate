      "genres": ["all"],
      "artifact_stages": ["outline", "draft", "final"],
      "tasks": ["outline", "scene", "prose", "revision"],
      "continuity_risks": ["open_loop", "chapter_boundary", "promise"],
      "query_terms": ["章末", "钩子", "悬念", "下一章", "追读"],
      "internal_checks": [
        "钩子是否源于本章因果而非凭空插入",
