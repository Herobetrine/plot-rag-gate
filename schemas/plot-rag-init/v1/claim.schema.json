{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plot-rag-gate.local/schemas/plot-rag-init/v1/claim.schema.json",
  "title": "Plot RAG Initialization Claim",
  "type": "object",
  "required": [
    "claim_id",
    "source_id",
    "source_version_id",
    "subject",
    "predicate",
    "object_or_value",
    "exact_evidence",
    "path",
    "line_start",
    "line_end",
    "source_hash",
    "support_type",
    "source_role",
    "authority_tier",
    "field_status",
    "canon_status",
    "origin",
    "scope",
    "knowledge_plane",
    "modality",
    "branch_id",
    "confidence"
  ],
  "properties": {
    "claim_id": {"type": "string", "pattern": "^claim-[a-f0-9]+$"},
    "source_id": {"type": "string"},
    "source_version_id": {"type": "string"},
    "subject": {"type": "string", "minLength": 1},
    "predicate": {"type": "string", "minLength": 1},
    "object_or_value": true,
    "exact_evidence": {"type": "string", "minLength": 1},
    "path": {"type": "string", "minLength": 1},
    "line_start": {"type": "integer", "minimum": 1},
    "line_end": {"type": "integer", "minimum": 1},
    "source_hash": {
      "$ref": "common.schema.json#/$defs/sha256"
    },
    "support_type": {"enum": ["exact", "paraphrase", "inference"]},
    "source_role": {"type": "string"},
    "authority_tier": {"type": "string"},
    "field_status": {"type": "string"},
    "canon_status": {"enum": ["proposed", "accepted", "rejected", "retracted"]},
    "origin": {"enum": ["source_extract", "model_suggestion", "deterministic_derived"]},
    "scope": {
      "type": ["string", "null"],
      "enum": ["current", "planned", "historical", "timeless", null]
    },
    "knowledge_plane": {
      "enum": [
        "objective",
        "actor_belief",
        "public_narrative",
        "reader_disclosed",
        "author_plan"
      ]
    },
    "modality": {"enum": ["asserted", "hypothetical", "conditional"]},
    "branch_id": {"type": "string"},
    "story_time": {"type": ["object", "null"]},
    "extraction_model": {"type": "string"},
    "prompt_version": {"type": "string"},
    "response_hash": {"type": "string"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1}
  },
  "additionalProperties": false
}
