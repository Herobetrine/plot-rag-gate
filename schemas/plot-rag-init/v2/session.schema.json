{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plot-rag-gate.local/schemas/plot-rag-init/v2/session.schema.json",
  "title": "Plot RAG Initialization Session v2",
  "type": "object",
  "required": ["schema_version", "bundle_schema_version", "session_id", "requested_mode", "mode", "target_profile", "interaction_profile", "stage", "status", "workspace_root", "session_revision", "expected_canon_revision", "source_snapshot_hash", "answers", "decisions", "dependency_graph", "created_at", "updated_at"],
  "properties": {
    "schema_version": {"const": "plot-rag-init/v2"},
    "bundle_schema_version": {"const": "plot-rag-init/v2"},
    "session_id": {"type": "string"},
    "requested_mode": {"enum": ["auto", "new", "ingest", "hybrid"]},
    "mode": {"type": ["string", "null"]},
    "target_profile": {"type": "string"},
    "interaction_profile": {"type": "string"},
    "stage": {"type": "string"},
    "status": {"type": "string"},
    "workspace_root": {"type": "string"},
    "session_revision": {"type": "integer"},
    "expected_canon_revision": {"type": "integer"},
    "source_snapshot_hash": {"type": "string"},
    "answers": {"type": "object"},
    "decisions": {"type": "array"},
    "dependency_graph": {"type": "object"},
    "created_at": {"type": "string"},
    "updated_at": {"type": "string"}
  },
  "additionalProperties": true
}
